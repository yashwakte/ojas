{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority",
    "DatabaseName": "OjasDb"
  },
  "Jwt": {
    "Key": "<your-secret-key-at-least-32-characters>",
    "Issuer": "OjasApi",
    "Audience": "OjasApp"
  }
}
